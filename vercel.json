{
  "rewrites": [
    { "source": "/games/(.*)", "destination": "/games/$1" }
  ],
  "headers": [
    {
      "source": "/games/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}
